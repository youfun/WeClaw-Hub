# WeClaw Agent Hooks 环境变量配置
#
# 复制此文件为 .env 或用 export 设置:
#   cp .env.example .env
#   source .env

# WeClaw-Hub webhook URL（在管理后台 /admin 创建 webhook 配置后获得）
WECLAW_WEBHOOK_URL=https://weclaw-hub.YOUR-DOMAIN.workers.dev/webhooks/agent_notify_xxx

# Bearer token — 仅当 webhook verify 模式为 "bearer" 时需要
# 如果在 WeClaw-Hub 管理后台将 verify 设为 "none"，此项可留空或删除
WECLAW_WEBHOOK_SECRET=YOUR_SECRET_TOKEN_HERE

# [可选] 覆盖 agent 名称，不设则自动从 hook 参数推断
WECLAW_AGENT_NAME=macbook-pro

# [可选] 防重复通知间隔（秒），默认无限制
# WECLAW_SUPPRESS_DUPS=60