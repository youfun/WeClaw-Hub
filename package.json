{
  "name": "weclaw-hub",
  "version": "0.4.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:local": "./scripts/dev-local.sh",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:local": "bun test src/__tests__/local/",
    "build": "bun build src/local/server.ts --bundle --target bun --outfile dist/bundle.js",
    "build:compile": "bun build src/local/server.ts --compile --outfile dist/weclaw-hub",
    "build:worker-bundle": "./scripts/build-worker-bundle.sh",
    "deploy:service": "cd deploy-service && bun run deploy"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.3",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/bun": "latest",
    "@types/node": "^25.9.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.76.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "hono": "^4.12.9",
    "qrcode-generator": "^2.0.4"
  }
}
